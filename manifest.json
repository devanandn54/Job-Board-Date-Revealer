{
  "manifest_version": 3,
  "name": "Job Board Date Revealer",
  "version": "1.2",
  "description": "Fetches hidden dates and scans for Visa/Clearance requirements on Greenhouse, Ashby, and Lever.",
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*/jobs/*",
        "https://job-boards.greenhouse.io/*/jobs/*",
        "https://jobs.ashbyhq.com/*",
        "https://jobs.lever.co/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}